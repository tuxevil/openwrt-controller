#!/bin/sh /etc/rc.common

USE_PROCD=1
START=99
STOP=15

# Resolve the agent script path. The script has been installed in different
# places across the fleet due to historical setup differences:
#   /usr/sbin/nerve-agent.sh   — created by 99-nerve-center-bootstrap (Alpine)
#   /etc/agent.sh              — older Alpine deploys (e.g. WNDR3800)
#   /root/agent.sh             — even older Alpine deploys (mr8300, uapmesh)
# We pick the first one that exists and is executable. This lets the same
# init script be pushed to any node without breaking it.
start_service() {
    local agent_script=""
    for candidate in \
        /usr/sbin/nerve-agent.sh \
        /etc/agent.sh \
        /root/agent.sh; do
        if [ -x "$candidate" ]; then
            agent_script="$candidate"
            break
        fi
    done
    if [ -z "$agent_script" ]; then
        logger -t agent "FATAL: no agent script found in /usr/sbin/nerve-agent.sh, /etc/agent.sh, /root/agent.sh"
        return 1
    fi

    procd_open_instance
    procd_set_param command /bin/sh "$agent_script"
    # procd_set_param respawn <threshold_seconds> <timeout_seconds> <retry_count>
    # NOTE: procd parses the three positional args in this exact order:
    #   1st = threshold (window in seconds, default 3600)
    #   2nd = timeout   (seconds to wait between restarts, default 5)
    #   3rd = retry     (max crashes within the threshold, default 5)
    # Defaults of 3600/5/5 cause the service to enter "crash loop" mode and
    # stop respawning after ~5 self-updates within an hour. The agent's
    # auto-updater re-execs the script in place, but procd still treats the
    # initial crash as countable. We set retry=999 so legitimate self-updates
    # never trip the crash threshold.
    procd_set_param respawn 3600 1 999
    procd_set_param stdout 1 # Manda los logs al sistema (logread)
    procd_set_param stderr 1
    procd_close_instance
}