#!/bin/sh /etc/rc.common

USE_PROCD=1
START=99
STOP=15

start_service() {
    procd_open_instance
    procd_set_param command /bin/sh /root/agent.sh
    # procd_set_param respawn <threshold_seconds> <retry_count> <timeout_seconds>
    # Defaults of 3600/5/5 cause the service to enter "crash loop" mode and stop
    # respawning after ~5 self-updates within an hour. The agent's auto-updater
    # exits the process to reload itself, which procd counts as a crash. We set
    # retry=999 so legitimate self-updates never trip the crash threshold.
    procd_set_param respawn 3600 999 1
    procd_set_param stdout 1 # Manda los logs al sistema (logread)
    procd_set_param stderr 1
    procd_close_instance
}