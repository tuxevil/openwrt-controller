# Copia este archivo a .env y rellena con valores reales.
# JAMÁS commitees .env

# PostgreSQL
POSTGRES_PASSWORD=GENERATE_STRONG_PASSWORD_HERE
DATABASE_URL=postgres://postgres:GENERATE_STRONG_PASSWORD_HERE@localhost:5432/openwrthub

# JWT (mínimo 32 chars, usa `openssl rand -base64 48`)
JWT_SECRET=GENERATE_WITH_openssl_rand_base64_48

# InfluxDB
INFLUX_URL=http://localhost:8086
INFLUX_ORG=openwrthub
INFLUX_BUCKET=telemetry
INFLUX_TOKEN=GENERATE_TOKEN_IN_INFLUXDB_UI
INFLUXDB_PASSWORD=GENERATE_STRONG_PASSWORD_HERE

# SuperAdmin bootstrap (opcional — si no se setea, se genera aleatoria y se loguea)
SUPERADMIN_DEFAULT_PASSWORD=
